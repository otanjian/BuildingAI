# SAP ADT (HTTPS). Confirm host/port with your basis team; ADT must be enabled.
# Example for instance 00: https://sap.example.com:44300
SAP_URL=https://sap.goodsap.cn:44300
SAP_USER=S2385
SAP_PASSWORD=your-password
SAP_CLIENT=200
SAP_LANGUAGE=ZH

# stateless (default) works better on ECC; use stateful for some S/4 features
SAP_SESSION_TYPE=stateless

# Self-signed SAP certificates (yan252 server sets this internally; keep for child process)
NODE_TLS_REJECT_UNAUTHORIZED=0

# HTTP gateway (supergateway → BuildingAI streamable-http)
MCP_HOST=127.0.0.1
MCP_PORT=8100
MCP_PATH=/mcp

# Upstream repo pin (optional)
MCP_ABAP_ADT_REPO=https://github.com/yan252/mcp-abap-abap-adt-api.git
MCP_ABAP_ADT_REF=main
