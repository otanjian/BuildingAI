# SAP RFC connection (PyRFC + libsapnwrfc)
SAP_ASHOST=
SAP_SYSNR=00
SAP_CLIENT=100
SAP_USER=
SAP_PASSWORD=
SAP_LANGUAGE=EN
SAP_SAPROUTER=

# ADT HTTPS fallback (auto-loaded from ../sap-abap-adt-mcp/.env if present)
# Used when PyRFC is unavailable — read_table / run_query work via ADT REST API
SAP_URL=
SAP_SESSION_TYPE=stateless
SAP_TLS_VERIFY=false
SAP_ADT_TIMEOUT=60

# Backend selection: auto | pyrfc | adt
# auto = PyRFC when installed + RFC host configured, else ADT when SAP_URL set
SAP_BACKEND=auto

# Message server logon (alternative to SAP_ASHOST):
# SAP_MSHOST=
# SAP_MSSERV=3601
# SAP_GROUP=SPACE
# SAP_R3NAME=S4H

# NW RFC SDK path (set by install-nwrfcsdk.sh)
# SAPNWRFC_HOME=

# HTTP gateway (supergateway → BuildingAI streamable-http)
MCP_HOST=127.0.0.1
MCP_PORT=8200
MCP_PATH=/mcp
